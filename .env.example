# Database (local PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# Supabase (Authentication — required for production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Supabase Service Role Key (optional — needed for admin user management)
# Get this from Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Auth secret for encryption (change in production)
AUTH_SECRET=portinel-change-this-to-a-random-secret

# Optional: AI providers can be configured via Admin Panel instead
# OPENROUTER_API_KEY=
# DEEPSEEK_API_KEY=
